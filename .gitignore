# ============================================================================
# Career Pilot .gitignore
# Base: NanoClaw v2 upstream + career-pilot-specific additions
# ============================================================================

# --- NanoClaw upstream ---

# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - per-installation state, not tracked by default in upstream.
# Career-pilot exception: we COMMIT our own custom agent groups under
# well-known names so the repo is forkable. Anything else under groups/
# stays per-installation.
groups/*
!groups/career-pilot/
!groups/career-pilot-sandbox/
!groups/_shared-skills/
!groups/_shared-subagents/
# NanoClaw upstream default group skeletons — tracked in upstream, so we track them too
!groups/global/
!groups/main/
# Within our committed groups, gitignore generated/per-install artifacts.
# Note: groups/<name>/CLAUDE.md is composer-managed (regenerated every
# container spawn by src/claude-md-compose.ts), as is .claude-fragments/.
# CLAUDE.local.md is agent-writable per-group memory. None of these should
# be committed — the composer owns one set; the agent owns the other.
groups/*/CLAUDE.md
groups/*/CLAUDE.local.md
groups/*/.claude-shared.md
groups/*/.claude-fragments/

# Career-pilot host-fragments — see src/claude-md-compose.ts file header.
# The `persona.md` fragment is hand-authored (committed). The `candidate.md`
# fragment is host-rendered per-deployment from candidate_profile and
# contains PII — never commit.
groups/*/.claude-host-fragments/candidate.md

# Subagent definitions are composer-managed — sources live in
# .claude/agents-src/ (committed) and get rendered into .claude/agents/
# at spawn with shared preamble inlined. See src/claude-md-compose.ts
# (composeSubagentDefinitions) and .specs/STRATEGY.md §24.3 item 2.
groups/*/.claude/agents/*.md

# container.json is rewritten on every container spawn by
# materializeContainerJson() from the central DB (`container_configs`
# table is the source of truth). Contents are per-deployment — agentGroupId
# is randomized by setup-test.ts --reset, model/env/blockedHosts flip with
# OLLAMA_TEST_MODE, image_tag includes the per-checkout install slug. The
# legacy backfill path handles a missing file gracefully (uses defaults),
# so nothing depends on a committed copy.
groups/*/container.json

# Composer-managed CLAUDE.md artifacts (regenerated every spawn) and
# per-group memory (CLAUDE.local.md) must never be committed — these
# **/-prefix variants catch group folders that don't match the groups/*/
# pattern above (e.g. nested test fixtures).
**/CLAUDE.local.md
**/.claude-shared.md
**/.claude-fragments/

# Secrets
*.keys.json
.env
.env*
!.env.example

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs

# --- Career-pilot additions ---

# OneCLI local vault state (per-installation)
.onecli-vault/

# Local dev DBs (separate from production data/)
*.dev.db
*.dev.db-journal
*.dev.db-shm
*.dev.db-wal
*.sqlite

# Terraform local state — NEVER commit (contains secrets and live infra state)
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.tfstate.lock.info

# Test artifacts
coverage/
.vitest-cache/

# Frontend build output (TanStack Start on Cloudflare Workers, Phase 5+)
.wrangler/
frontend/.output/
frontend/.tanstack/
frontend/dist/
