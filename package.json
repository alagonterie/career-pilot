{
  "name": "nanoclaw",
  "version": "2.0.70",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "bin": {
    "ncl": "bin/ncl"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:mock": "tsx scripts/portal-dev-server.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "setup:auto": "tsx setup/auto.ts",
    "ncl": "tsx src/cli/client.ts",
    "chat": "tsx scripts/chat.ts",
    "health": "tsx scripts/health-check.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:check-ollama": "tsx scripts/test/check-ollama.ts",
    "test:setup": "tsx scripts/test/setup-test.ts",
    "test:e2e": "tsx scripts/test/e2e.ts",
    "cleanup:onecli-agents": "tsx scripts/cleanup-onecli-agents.ts"
  },
  "dependencies": {
    "@chat-adapter/telegram": "4.26.0",
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "@onecli-sh/sdk": "^0.5.0",
    "@react-pdf/renderer": "^4.5.1",
    "better-sqlite3": "11.10.0",
    "chat": "^4.24.0",
    "cron-parser": "5.5.0",
    "jose": "^6.2.3",
    "kleur": "^4.1.5",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.16",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
