# =====================================================================
# career-pilot — environment variables template
# =====================================================================
# Copy to `.env` and fill in actual values. `.env` is gitignored.
# See .specs/STRATEGY.md §12 for the full credential layering model
# (OneCLI → Portkey gateway OR direct → Anthropic).
# =====================================================================

# --- Core NanoClaw runtime (existing upstream vars) ---

# Display name the agent uses when introducing itself outside the chat.
# Defaults to "Andy" upstream; we override to the candidate's preferred name.
ASSISTANT_NAME=

# OneCLI credential vault connection. The setup wizard sets these on first
# run; copy them out of OneCLI's printout if you need to re-link.
ONECLI_URL=http://127.0.0.1:8765
ONECLI_API_KEY=

# Timezone for cron schedules + briefings. IANA name (e.g. America/Chicago).
# Falls back to the system zone if unset.
TZ=

# --- Career-pilot LLM routing ---

# Portkey is the production LLM gateway. Provider slug is the workspace-
# scoped name in Portkey's Model Catalog (Integrations + AI Providers).
PORTKEY_API_KEY=
PORTKEY_AI_PROVIDER=anthropic-default

# Optional bypass: when set to "true", containers spawn with
# ANTHROPIC_BASE_URL pointing at the direct Anthropic endpoint and OneCLI
# injects ANTHROPIC_API_KEY at request time. Use during Portkey outages
# or budget-exhausted scenarios. See STRATEGY.md §12.
PORTKEY_BYPASS=false
ANTHROPIC_API_KEY=

# --- Telegram channel (owner chat) ---

# Two bots: prod (real candidate↔agent) and dev (test environment).
# Run /add-telegram skill to pair either one.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEV_BOT_TOKEN=

# --- Test infrastructure (Phase 1.5) ---

# When set to "1" + agent group folder is "career-pilot", the container
# config is overlaid with Ollama routing (env vars, blockedHosts,
# model=qwen3-coder:30b). Used by the E2E test orchestrator to exercise
# the full pipeline against a local Ollama daemon at zero LLM cost.
# Leave unset for production runs.
OLLAMA_TEST_MODE=

# Ollama daemon URL — defaults to http://localhost:11434. Override only if
# you're running Ollama on a non-default host/port.
OLLAMA_URL=

# Override the test-mode model. Defaults to qwen3-coder:30b.
# Pull alternates via `ollama pull <model>`.
OLLAMA_TEST_MODEL=

# --- Cloudflare (Phase 8+ deploy pipeline) ---

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_TOKEN=

# --- GCP (Phase 8+ deploy pipeline) ---

GCP_PROJECT=
GCP_REGION=us-central1
